; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Motion"
run/main_scene="uid://cppfb3dyhpkq4"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/bg_color=Color(0.24705882, 0.3764706, 0.92941177, 1)
boot_splash/use_filter=true
config/icon="res://assets/icon.svg"

[autoload]

MultiplayerManager="*res://scripts/multiplayer_manager.gd"
Talo="*uid://bpmdn8oc34pg7"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg", "res://addons/talo/plugin.cfg")

[global_group]

camera=""

[input]

